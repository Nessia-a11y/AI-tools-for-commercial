  PORTKEY_API_KEY=your-portkey-api-key-here
  PORTKEY_VIRTUAL_KEY=optional-virtual-key
  PORTKEY_CONFIG=optional-config-id
  MODEL=claude-opus-4-8
  HOST=0.0.0.0
  PORT=3587
  ADMIN_TOKEN=set-a-strong-token-here
  # First admin: this email will be auto-promoted to admin on startup (must register first)
  INITIAL_ADMIN_EMAIL=your-admin@company.com

  # SMTP for email verification (OTP codes)
  SMTP_HOST=smtp.gmail.com
  SMTP_PORT=587
  SMTP_USER=your-email@gmail.com
  SMTP_PASS=your-app-password
  SMTP_FROM=noreply@yourcompany.com
